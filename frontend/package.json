{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm": "sh -c 'cd .. && PATH=\"${CARGO_HOME:-$HOME/.cargo}/bin:$PATH\" wasm-pack build --target web'",
    "sync:graph": "mkdir -p public && cp ../artifacts/graph.gcr public/graph.gcr",
    "dev": "npm run wasm && npm run sync:graph && vite",
    "build": "npm run wasm && npm run sync:graph && vite build",
    "preview": "vite preview",
    "check": "npm run wasm && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "playwright-core": "^1.58.2",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-wasm-pack": "^0.1.12"
  }
}
